{
  "name": "apk-info-parser",
  "version": "1.0.2",
  "description": "APK signature and certificate parser for Node.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "apk",
    "android",
    "signature",
    "certificate",
    "x509",
    "pkcs7"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
